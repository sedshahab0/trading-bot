# Production configuration template.
# Copy to /opt/trading-bot/.env, fill secrets, then chmod 600.

# Market data
TWELVE_DATA_API_KEY=f885bc0d86e54c14ad768c94a926e541
DATA_PROVIDER=twelvedata
SYMBOLS=EUR/USD,GBP/USD,XAU/USD,USD/JPY,XAG/USD
MIN_SCORE=10
POLL_SECONDS=120
SIMULATION_EXPIRY_HOURS=72

# Telegram
TELEGRAM_BOT_TOKEN=8645295769:AAFNKoOjTjIqb7B9mEQ9jXZ61gswIXTFBWw
TELEGRAM_CHAT_ID=-1003939765500
SEND_STARTUP_MESSAGE=1
NOTIFICATIONS_PAUSED=0

# Facebook bridge
FACEBOOK_ENABLE=1
FACEBOOK_URL=http://127.0.0.1:5005/signal
FACEBOOK_BASIS=SMC Structure + Liquidity Grab + Daily Bias
FACEBOOK_AUTO_POST=0

# Dashboard and deploy
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=tradingbot2026
BEHIND_PROXY=1
DEPLOY_BRANCH=main
DEPLOY_HOOK_TOKEN=5b2b1bbd68b6af6113e640134c28ca2f77f27c71825f91d3
GH_PAT=IN_SERVER_ENV_ONLY

# Engine behavior
ENGINE_DEBUG=0
SESSION_ENABLE=1
SESSION_START_HOUR=7
SESSION_END_HOUR=20
STRATEGY_MQ5_PATH=/opt/trading-bot/strategy/active.mq5

# Runtime paths
BOT_ROOT=/opt/trading-bot
BOT_DATA_ROOT=/var/lib/trading-bot
SIGNAL_LOG_FILE=/var/lib/trading-bot/signal_log.txt
SIGNAL_QUEUE_FILE=/var/lib/trading-bot/signal_queue.json
SIMULATION_DB=/var/lib/trading-bot/signal-simulation.sqlite3
TELEGRAM_DELIVERY_LOG=/var/lib/trading-bot/telegram_delivery.log
SIGNAL_OUTCOMES_LOG=/var/lib/trading-bot/signal_outcomes.log
DASHBOARD_AUDIT_LOG=/var/lib/trading-bot/dashboard_audit.log

# Monitoring and operations
ALERT_CPU_THRESHOLD=85
ALERT_RAM_THRESHOLD=85
ALERT_DISK_THRESHOLD=90
WEBHOOK_DISCORD_URL=
WEBHOOK_SLACK_URL=
WEBHOOK_ON_SIGNAL=0
MAINTENANCE_ENABLED=0
MAINTENANCE_WINDOW=22:00-06:00
